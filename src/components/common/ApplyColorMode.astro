---
// Single-theme (light-only) mode
---

<script is:inline>
  // Always force light theme; ignore system preference and any stored theme
  document.documentElement.classList.remove('dark');

  const matches = document.querySelectorAll('[data-aw-toggle-color-scheme] > input');
  if (matches && matches.length) {
    matches.forEach((elem) => {
      // Keep any existing toggle visually on the "light" state
      elem.checked = true;
    });
  }
</script>
