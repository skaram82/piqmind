---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="Contact" title="Contact us" />

  <ContactUs
    id="form"
    title=""
    subtitle="Drop us a message using the form below, or feel free to email us directly. We’ll get back to you as soon as possible."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
    ]}
    textarea={{
      label: 'Message',
    }}
    disclaimer={{
      label:
        'We’ll only use your name, email address, and message to reply to you. You can read more about how we handle your data in our Privacy Policy.',
    }}
    description=""
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="We are here to help!"
    items={[
      {
        title: 'Phone',
        description: '+30 (2310) 000000',
        icon: 'tabler:headset',
      },
      {
        title: 'Email',
        description: 'info@piqmind.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Location',
        description: 'Komninon 80, GR55132, Kalamaria, Greece',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>
